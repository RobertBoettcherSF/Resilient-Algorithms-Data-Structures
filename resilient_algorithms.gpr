-- resilient_algorithms.gpr
-- Version: 0.04
-- GNAT project file for resilient algorithms in SPARK

project resilient_algorithms is

   for Source_Dirs use ("");
   for Main use ("main.adb");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";

   package Compiler is
      for Switches ("Ada") use ("-gnatwa", "-gnata", "-gnatN");
   end Compiler;

   package Proof is
      for Switches ("Ada") use ("-gnatwa", "-gnata", "-gnatN");
   end Proof;

end resilient_algorithms;
